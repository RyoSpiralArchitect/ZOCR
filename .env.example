# Reference API (FastAPI)
# Copy to `.env` for `docker compose` (optional).

# Enable auth (recommended in internal networks)
# ZOCR_API_KEY=change-me
# ZOCR_API_AUTH_MODE=api_key

# Auth backend
# `auto` chooses `jwt`, `api_key`, `hybrid`, or `none` from configured secrets/keys.
ZOCR_API_AUTH_MODE=auto

# API key auth
# Legacy single key:
# ZOCR_API_KEY=change-me
# ZOCR_API_KEY_TENANT=default
# ZOCR_API_KEY_ROLES=operator
# ZOCR_API_KEY_SCOPES=
# Multi-key JSON:
# ZOCR_API_KEYS_JSON={"tenant-a-key":{"tenant_id":"tenant-a"},"admin-key":{"admin":true,"tenant_id":"*"}}
# Optional built-in roles: `viewer`, `operator`, `admin`

# Authorization hardening
ZOCR_API_AUTHZ_STRICT=0
# When `1`, principals without explicit roles/scopes are denied on scoped routes.

# JWT auth (HS256/384/512)
# ZOCR_API_JWT_SECRET=change-me
# Or use JWKS / OIDC instead of a shared secret:
# ZOCR_API_JWT_JWKS_URL=https://issuer.example/.well-known/jwks.json
# ZOCR_API_JWT_JWKS_PATH=/run/secrets/jwks.json
# ZOCR_API_JWT_JWKS_JSON={"keys":[...]}
# ZOCR_API_OIDC_DISCOVERY_URL=https://issuer.example/.well-known/openid-configuration
# ZOCR_API_JWT_JWKS_CACHE_TTL_SEC=300
# ZOCR_API_JWT_ALGORITHMS=HS256
# For typical OIDC/JWKS providers, use: ZOCR_API_JWT_ALGORITHMS=RS256
# ZOCR_API_JWT_ISSUER=
# ZOCR_API_JWT_AUDIENCE=
# ZOCR_API_JWT_TENANT_CLAIM=tenant_id
# ZOCR_API_JWT_SUBJECT_CLAIM=sub
# ZOCR_API_JWT_ROLES_CLAIM=roles
# ZOCR_API_JWT_SCOPE_CLAIM=scope
# ZOCR_API_JWT_ADMIN_CLAIM=is_admin
# ZOCR_API_JWT_ADMIN_SCOPE=zocr.admin
# ZOCR_API_JWT_CLOCK_SKEW_SEC=30

# Use a pre-built image (recommended for offline/internal delivery)
# ZOCR_API_IMAGE=zocr-suite:latest

# Build options (only used when building the image locally with `docker compose build`)
# ZOCR_EXTRAS=api
# SaaS profile example (Redis queue + S3 storage):
#   ZOCR_EXTRAS=api,api_s3,api_redis,api_db
# ZOCR_APT_PACKAGES=poppler-utils
# Example (enable Tesseract OCR in the image):
#   ZOCR_EXTRAS=api,ocr_tess
#   ZOCR_APT_PACKAGES=poppler-utils tesseract-ocr tesseract-ocr-eng
#
# Example (enable multimodal PDF ingest + Parquet export in the image):
#   ZOCR_EXTRAS=api,multimodal,parquet
#   ZOCR_APT_PACKAGES=poppler-utils

# Limits / performance
ZOCR_API_MAX_UPLOAD_MB=50
ZOCR_API_WORKERS=1
ZOCR_API_CONCURRENCY=1
ZOCR_API_RUN_TIMEOUT_SEC=900
ZOCR_API_RATE_LIMIT_PER_MIN=0
ZOCR_API_RATE_LIMIT_BACKEND=local
# ZOCR_API_RATE_LIMIT_REDIS_URL=redis://redis:6379/0
ZOCR_API_RATE_LIMIT_REDIS_PREFIX=zocr_rate_limit
# ZOCR_API_RATE_LIMIT_WINDOW_SEC=60

# Storage backend
ZOCR_API_STORAGE_BACKEND=local

# Metadata backend
ZOCR_API_METADATA_BACKEND=local

# Job persistence root / local cache (Docker: mounted volume)
ZOCR_API_STORAGE_DIR=/data

# Queue backend
ZOCR_API_QUEUE_BACKEND=inline

# Redis queue settings (used when ZOCR_API_QUEUE_BACKEND=redis)
ZOCR_API_REDIS_URL=redis://redis:6379/0
ZOCR_API_REDIS_STREAM=zocr_jobs
ZOCR_API_REDIS_GROUP=zocr_workers

# Worker settings (used by `zocr-worker`)
ZOCR_WORKER_BLOCK_MS=5000
ZOCR_WORKER_CLAIM_IDLE_MS=60000
ZOCR_WORKER_CLAIM_COUNT=10

# Postgres metadata (used when ZOCR_API_METADATA_BACKEND=postgres)
ZOCR_API_DATABASE_URL=postgresql://zocr:zocr@postgres:5432/zocr
ZOCR_API_DB_AUTO_INIT=1

# Tenant scoping
ZOCR_API_MULTI_TENANT_ENABLED=0
# ZOCR_API_DEFAULT_TENANT=default
# Set `ZOCR_API_DEFAULT_TENANT=` (blank) to require `X-Tenant-ID` on every request.
ZOCR_API_TENANT_MAX_ACTIVE_JOBS=0
ZOCR_API_TENANT_MAX_STORED_JOBS=0
ZOCR_API_TENANT_APPROVAL_REQUIRED=0
# When `1`, tenant plan/policy write APIs and `zocr-admin` mutations create pending change requests.
ZOCR_API_TENANT_APPROVAL_ALLOW_SELF=0
# When `0`, the requester cannot approve their own pending change request.
ZOCR_API_TENANT_APPROVAL_MIN_APPROVERS=1
# Set to `2` (or more) to require multiple distinct approvers before a change is applied.
# ZOCR_API_TENANT_APPROVAL_NOTIFY_URL=https://ops.example/tenant-approvals
# ZOCR_API_TENANT_APPROVAL_NOTIFY_TIMEOUT_SEC=2
# ZOCR_API_TENANT_APPROVAL_NOTIFY_HEADERS_JSON={"Authorization":"Bearer ..."}
# ZOCR_API_TENANT_PLANS_JSON={"starter":{"rate_limit_per_min":60,"max_active_jobs":2,"max_stored_jobs":50}}
# ZOCR_API_TENANT_POLICIES_JSON={"tenant-a":{"plan":"starter"}}

# S3 / MinIO storage (used when ZOCR_API_STORAGE_BACKEND=s3)
# ZOCR_API_S3_BUCKET=zocr-prod
# ZOCR_API_S3_PREFIX=zocr
# ZOCR_API_S3_REGION=us-west-2
# ZOCR_API_S3_ENDPOINT_URL=
# ZOCR_API_S3_FORCE_PATH_STYLE=0
# ZOCR_API_S3_PRESIGN_ENABLED=1
# ZOCR_API_S3_PRESIGN_TTL_SEC=3600

# Job retention
ZOCR_API_JOBS_MAX_COUNT=200
ZOCR_API_JOBS_TTL_HOURS=168

# Startup behavior
ZOCR_API_JOBS_RESUME_ON_STARTUP=1
ZOCR_API_JOBS_CLEANUP_ON_STARTUP=1
ZOCR_API_JOBS_CLEANUP_ON_CREATE=1

# Observability
ZOCR_API_LOG_FORMAT=json
ZOCR_API_LOG_LEVEL=INFO
ZOCR_API_METRICS_ENABLED=1
ZOCR_API_AUDIT_SINKS=
ZOCR_API_AUDIT_READ_BACKEND=auto
# file sink:
# ZOCR_API_AUDIT_LOG_PATH=/data/audit/zocr_audit.jsonl
# postgres sink:
# ZOCR_API_AUDIT_DATABASE_URL=postgresql://zocr:zocr@postgres:5432/zocr
# ZOCR_API_AUDIT_DB_AUTO_INIT=1
# http / SIEM sink:
# ZOCR_API_AUDIT_HTTP_URL=https://siem.example/events
# ZOCR_API_AUDIT_HTTP_TIMEOUT_SEC=2
# ZOCR_API_AUDIT_HTTP_HEADERS_JSON={"Authorization":"Bearer ..."}

# Artifacts zip (download performance vs size)
# ZOCR_API_ZIP_COMPRESSION=deflated   # deflated (smaller) or stored (faster)
# ZOCR_API_ZIP_COMPRESSLEVEL=         # 0-9 (only for deflated; empty = default)
